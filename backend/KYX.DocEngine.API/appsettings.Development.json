{
  "Documents": {
    "AllowSyncPdfGeneration": true
  },
  "Hangfire": {
    "Storage": "Memory"
  },
  "Auth": {
    "UseDatabaseForLogin": true,
    "PasswordVerification": "BcryptOrMd5Hex",
    "UseAllowedLoginsFallback": false,
    "AllowedLogins": []
  },
  "Logging": {
    "PersistTbLogRequisicao": false
  },
  "Schema": {
    "Usuario": {
      "Id": "id_usuario",
      "Nome": "str_descricao",
      "Email": "email",
      "Login": "str_login",
      "Senha": "str_senha",
      "PerfilId": "",
      "Ativo": "bloqueado",
      "AtivoInverted": true,
      "CriadoEm": "dh_inclui",
      "AtualizadoEm": "dh_edita",
      "IdIntegerType": true,
      "UniqueEmailIndex": false
    },
    "LogRequisicao": {
      "Id": "id",
      "RequisicaoId": "requisicao_id",
      "UsuarioId": "usuario_id",
      "Canal": "",
      "CentroCusto": "centro_custo",
      "RequestPayload": "request_payload",
      "ResponsePayload": "response_payload",
      "StatusHttp": "status_http",
      "TempoRespostaMs": "tempo_resposta_ms",
      "Erro": "erro",
      "CriadoEm": "criado_em"
    }
  }
}
