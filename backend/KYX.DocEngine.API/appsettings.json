{
  "Port": 3000,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "PersistTbLogRequisicao": true
  },
  "AllowedHosts": "*",
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Hangfire": {
    "Storage": "Memory"
  },
  "Documents": {
    "AllowSyncPdfGeneration": false
  },
  "Auth": {
    "UseDatabaseForLogin": true,
    "PasswordVerification": "BcryptOrMd5Hex",
    "UseAllowedLoginsFallback": false,
    "AllowedLogins": []
  },
  "Schema": {
    "Usuario": {
      "Id": "id",
      "Nome": "nome",
      "Email": "email",
      "Login": "",
      "Senha": "senha",
      "PerfilId": "perfil_id",
      "Ativo": "ativo",
      "AtivoInverted": false,
      "CriadoEm": "criado_em",
      "AtualizadoEm": "atualizado_em",
      "IdIntegerType": false,
      "UniqueEmailIndex": true
    },
    "LogRequisicao": {
      "Id": "id",
      "RequisicaoId": "requisicao_id",
      "UsuarioId": "usuario_id",
      "Canal": "canal",
      "CentroCusto": "centro_custo",
      "RequestPayload": "request_payload",
      "ResponsePayload": "response_payload",
      "StatusHttp": "status_http",
      "TempoRespostaMs": "tempo_resposta_ms",
      "Erro": "erro",
      "CriadoEm": "criado_em"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=docengine;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "SecretKey": "change-me-in-production-minimum-32-characters",
    "Issuer": "KYX.DocEngine",
    "Audience": "KYX.DocEngine",
    "ExpirationMinutes": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175",
      "http://localhost:5176"
    ]
  }
}

