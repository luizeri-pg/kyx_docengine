  "inlineTemplate": {
    "type": "html",
    "content": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Dossiê probatório – Contratação Digital Simplix</title>\n  <style>\n    @page {\n      size: A4;\n      margin: 18mm 20mm 14mm 20mm;\n    }\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    html, body {\n      font-family: Arial, Helvetica, sans-serif;\n      color: #1a1a1a;\n      font-size: 14px;\n      line-height: 1.5;\n      -webkit-print-color-adjust: exact;\n      print-color-adjust: exact;\n      background: #fff;\n    }\n    /**\n     * Secções principais: quebra antes de cada bloco (exceto a primeira).\n     * Tabelas podem continuar em várias folhas; thead repete-se em cada página impressa.\n     * Rodapé com hash + \"k / N\": envie nos dados DOCENGINE_USE_CHROME_PAGE_FOOTER=true\n     * (HASH_DOSSIE no rodapé nativo do Chromium — sem PAGINA_TOTAL manual).\n     */\n    .dossie-section {\n      page-break-before: always;\n      position: relative;\n    }\n    .dossie-section--first {\n      page-break-before: auto;\n    }\n    .events-table thead,\n    .logs-table thead,\n    .bordered-table thead {\n      display: table-header-group;\n    }\n    .events-table tbody tr,\n    .logs-table tbody tr {\n      break-inside: avoid;\n      page-break-inside: avoid;\n    }\n\n    /* ─── Header ─── */\n    .header {\n      display: flex;\n      align-items: center;\n      gap: 16px;\n      margin-bottom: 24px;\n    }\n    .header-logo { height: 42px; }\n    .header-title {\n      font-size: 20px;\n      font-weight: 400;\n      color: #1a1a1a;\n    }\n\n    /* ─── Section title with blue bar ─── */\n    .section-title {\n      font-size: 18px;\n      font-weight: 400;\n      color: #1a1a1a;\n      padding-left: 12px;\n      border-left: 5px solid #2563eb;\n      margin: 28px 0 14px;\n    }\n    .section-title:first-of-type { margin-top: 0; }\n\n    /* ─── Client block ─── */\n    .client-block {\n      display: flex;\n      gap: 28px;\n      align-items: flex-start;\n      margin-top: 10px;\n    }\n    .client-photo {\n      width: 230px;\n      min-height: 280px;\n      overflow: hidden;\n      flex-shrink: 0;\n      background: #f5f5f5;\n    }\n    .client-photo img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      display: block;\n    }\n    .client-fields {\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n      padding-top: 10px;\n    }\n\n    /* ─── Field label / value ─── */\n    .field-label {\n      font-size: 15px;\n      color: #777;\n      margin-bottom: 2px;\n      display: block;\n    }\n    .field-value {\n      font-size: 16px;\n      color: #1a1a1a;\n      font-weight: 700;\n      display: block;\n    }\n    .field-value-normal {\n      font-size: 15px;\n      color: #1a1a1a;\n      font-weight: 700;\n      display: block;\n    }\n\n    /* ─── Capture data grid ─── */\n    .capture-grid {\n      margin-top: 10px;\n    }\n    .capture-row {\n      display: flex;\n      gap: 50px;\n      margin-bottom: 10px;\n    }\n    .capture-cell { min-width: 140px; }\n\n    /* ─── Events table ─── */\n    .events-table {\n      width: 100%;\n      border-collapse: collapse;\n      font-size: 14px;\n      margin-top: 8px;\n    }\n    .events-table th {\n      font-size: 14px;\n      font-weight: 400;\n      color: #555;\n      text-align: left;\n      padding: 6px 0;\n    }\n    .events-table thead tr {\n      border-bottom: 2px dotted #999;\n    }\n    .events-table td {\n      padding: 12px 6px 12px 0;\n      vertical-align: top;\n      line-height: 1.45;\n    }\n    .events-table tbody tr {\n      border-bottom: 2px dotted #bbb;\n    }\n    .events-table tbody tr:last-child {\n      border-bottom: none;\n    }\n    .events-table .col-evento { width: 22%; }\n    .events-table .col-data { width: 35%; text-align: center; }\n    .events-table .col-id { width: 43%; }\n    .events-table td:nth-child(2) { text-align: center; }\n\n    .id-line {\n      display: block;\n      font-size: 14px;\n      color: #333;\n      line-height: 1.5;\n    }\n\n    /* ─── Logs section ─── */\n    .logs-header {\n      margin-bottom: 8px;\n    }\n    .logs-header .field-row {\n      display: flex;\n      gap: 40px;\n      margin-top: 10px;\n    }\n    .logs-separator {\n      border: none;\n      border-top: 2px solid #333;\n      margin: 10px 0 0;\n    }\n    .logs-table {\n      width: 100%;\n      border-collapse: collapse;\n      font-size: 14px;\n    }\n    .logs-table th {\n      font-size: 14px;\n      font-weight: 400;\n      color: #555;\n      text-align: left;\n      padding: 8px 0;\n      border-bottom: 2px dotted #999;\n    }\n    .logs-table td {\n      padding: 8px 4px 8px 0;\n      vertical-align: top;\n      font-size: 13px;\n      line-height: 1.4;\n    }\n    .logs-table tbody tr {\n      border-bottom: 2px dotted #bbb;\n    }\n    .logs-table tbody tr:last-child {\n      border-bottom: none;\n    }\n    .logs-table .col-data-log { width: 20%; text-align: center; }\n    .logs-table .col-tipo { width: 18%; text-align: center; }\n    .logs-table .col-interacao { width: 62%; }\n    .logs-table td:nth-child(1) { text-align: center; }\n    .logs-table td:nth-child(2) { text-align: center; }\n\n    /* ─── Bordered table (CCB) ─── */\n    .bordered-table {\n      width: 100%;\n      border-collapse: collapse;\n      font-size: 11px;\n    }\n    .bordered-table th, .bordered-table td {\n      border: 1px solid #bbb;\n      padding: 5px 6px;\n      vertical-align: top;\n      text-align: left;\n    }\n    .bordered-table th {\n      background: #e8e8e8;\n      font-weight: 700;\n      font-size: 9px;\n      text-transform: uppercase;\n    }\n\n    /* ─── Legal / CCB ─── */\n    .legal-body {\n      font-size: 14px;\n      line-height: 1.65;\n      text-align: justify;\n      padding-left: 14px;\n    }\n    .legal-body p { margin: 6px 0; }\n    .legal-body h3 { font-size: 14px; font-weight: 700; margin: 12px 0 4px; text-decoration: underline; }\n    .legal-body ul { margin: 4px 0 8px 20px; }\n    .legal-body li { margin-bottom: 2px; }\n    .legal-body table { width: 100%; border-collapse: collapse; margin: 6px 0; font-size: 12px; }\n    .legal-body table th, .legal-body table td { border: 1px solid #bbb; padding: 4px 6px; text-align: left; vertical-align: top; }\n    .legal-body table th { background: #eee; font-weight: 700; }\n\n    .ccb-header {\n      display: flex;\n      justify-content: space-between;\n      align-items: flex-start;\n      margin-bottom: 8px;\n    }\n    .ccb-header-logo { height: 36px; }\n    .ccb-header-via { font-size: 10px; font-weight: 700; text-align: right; }\n    .ccb-title {\n      text-align: center;\n      font-size: 13px;\n      font-weight: 700;\n      text-transform: uppercase;\n      margin-bottom: 8px;\n    }\n    .ccb-section-num {\n      font-size: 10px;\n      font-weight: 700;\n      text-transform: uppercase;\n      margin: 8px 0 4px;\n      border-bottom: 1px solid #bbb;\n      padding-bottom: 2px;\n    }\n    .ccb-sub-title {\n      font-size: 10px;\n      font-weight: 700;\n      text-transform: uppercase;\n      margin: 4px 0 2px;\n      color: #1a1a1a;\n    }\n\n    /* CCB bordered data table */\n    .ccb-data {\n      width: 100%;\n      border-collapse: collapse;\n      font-size: 10px;\n      margin-bottom: 4px;\n    }\n    .ccb-data td {\n      border: 1px solid #999;\n      padding: 2px 5px;\n      vertical-align: top;\n      line-height: 1.35;\n    }\n    .ccb-data .lbl {\n      font-size: 8.5px;\n      color: #555;\n      display: block;\n    }\n    .ccb-data .val {\n      font-size: 10px;\n      color: #1a1a1a;\n      font-weight: 400;\n      display: block;\n    }\n    .ccb-data .val-bold {\n      font-size: 10px;\n      color: #1a1a1a;\n      font-weight: 700;\n      display: block;\n    }\n\n    .ccb-ops {\n      width: 100%;\n      border-collapse: collapse;\n      font-size: 9.5px;\n      margin-bottom: 4px;\n    }\n    .ccb-ops td {\n      border: 1px solid #999;\n      padding: 2px 5px;\n      vertical-align: top;\n      line-height: 1.35;\n    }\n    .ccb-ops .lbl { font-size: 8px; color: #555; display: block; }\n    .ccb-ops .val { font-size: 9.5px; display: block; }\n\n    .ccb-footer-via {\n      font-size: 7.5px;\n      color: #333;\n      border-top: 1px solid #ccc;\n      padding-top: 4px;\n      margin-top: 8px;\n      display: flex;\n      justify-content: space-between;\n    }\n    .ccb-footer-via-right { text-align: right; }\n\n    /* ─── Images ─── */\n    .img-container {\n      margin-top: 8px;\n    }\n    .img-container img {\n      max-width: 100%;\n      max-height: 420px;\n      display: block;\n    }\n    .img-doc-container {\n      display: flex;\n      align-items: flex-start;\n      justify-content: flex-start;\n      min-height: 180px;\n      margin-bottom: 10px;\n    }\n    .img-doc-container img {\n      max-width: 100%;\n      max-height: 480px;\n      object-fit: contain;\n    }\n  </style>\n</head>\n<body>\n  <!-- Rodapé hash + página/total: envie nos dados DOCENGINE_USE_CHROME_PAGE_FOOTER=true (HASH_DOSSIE). Sem isto não há rodapé numérico. -->\n\n  <!-- ═══ Dados do Cliente + Captura + Trilha (tabela pode continuar em várias folhas) ═══ -->\n  <div class=\"dossie-section dossie-section--first\">\n    <div class=\"header\">\n      <!-- LOGO_SIMPLIX_BASE64: envie data URI (data:image/png;base64,...) ou só o Base64 da imagem (PNG/JPEG/WebP/GIF). -->\n      <img class=\"header-logo\" src=\"{{LOGO_SIMPLIX_BASE64}}\" alt=\"Simplix\" />\n      <span class=\"header-title\">Dossiê probatório – Contratação Digital Simplix</span>\n    </div>\n\n    <div class=\"section-title\">Dados do cliente</div>\n    <div class=\"client-block\">\n      <div class=\"client-photo\">\n        <img src=\"{{IMG_CLIENTE_FOTO}}\" alt=\"Foto do cliente\" />\n      </div>\n      <div class=\"client-fields\">\n        <div>\n          <span class=\"field-label\">Nome do cliente</span>\n          <span class=\"field-value\">{{CLIENTE_NOME}}</span>\n        </div>\n        <div>\n          <span class=\"field-label\">CPF</span>\n          <span class=\"field-value\">{{CLIENTE_CPF}}</span>\n        </div>\n        <div>\n          <span class=\"field-label\">Data de Nascimento</span>\n          <span class=\"field-value\">{{CLIENTE_NASCIMENTO}}</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"section-title\">Dados da captura</div>\n    <div class=\"capture-grid\">\n      <div class=\"capture-row\">\n        <div class=\"capture-cell\">\n          <span class=\"field-label\">Data e Hora</span>\n          <span class=\"field-value-normal\">{{CAPTURA_DATA_HORA}}</span>\n        </div>\n        <div class=\"capture-cell\">\n          <span class=\"field-label\">Latitude</span>\n          <span class=\"field-value-normal\">{{CAPTURA_LATITUDE}}</span>\n        </div>\n        <div class=\"capture-cell\">\n          <span class=\"field-label\">Longitude</span>\n          <span class=\"field-value-normal\">{{CAPTURA_LONGITUDE}}</span>\n        </div>\n      </div>\n      <div class=\"capture-row\">\n        <div class=\"capture-cell\">\n          <span class=\"field-label\">IP</span>\n          <span class=\"field-value-normal\">{{CAPTURA_IP}}</span>\n        </div>\n        <div class=\"capture-cell\">\n          <span class=\"field-label\">Porta Lógica</span>\n          <span class=\"field-value-normal\">{{CAPTURA_PORTA}}</span>\n        </div>\n      </div>\n      <div>\n        <span class=\"field-label\">Modelo/OS</span>\n        <span class=\"field-value-normal\">{{CAPTURA_MODELO_OS}}</span>\n      </div>\n    </div>\n\n    <div class=\"section-title\">Trilha de eventos</div>\n    <table class=\"events-table\">\n      <thead>\n        <tr>\n          <th class=\"col-evento\">Evento</th>\n          <th class=\"col-data\">Data e hora (GMT)</th>\n          <th class=\"col-id\">Identificação</th>\n        </tr>\n      </thead>\n      <tbody>{{EVENTOS_HTML}}</tbody>\n    </table>\n  </div>\n\n  <!-- ═══ Logs das integrações ═══ -->\n  <div class=\"dossie-section\">\n    <div class=\"section-title\" style=\"margin-top:0;\">Logs das integrações com o cliente</div>\n\n    <div class=\"logs-header\">\n      <div>\n        <span class=\"field-label\">Nome do cliente</span>\n        <span class=\"field-value\">{{CLIENTE_NOME}}</span>\n      </div>\n      <div class=\"field-row\" style=\"display:flex;gap:40px;margin-top:10px;\">\n        <div>\n          <span class=\"field-label\">Protocolo de atendimento</span>\n          <span class=\"field-value-normal\">{{PROTOCOLO_ATENDIMENTO}}</span>\n        </div>\n        <div>\n          <span class=\"field-label\">Data e hora início atendimento</span>\n          <span class=\"field-value-normal\">{{ATENDIMENTO_INICIO}}</span>\n        </div>\n      </div>\n    </div>\n\n    <hr class=\"logs-separator\" />\n\n    <table class=\"logs-table\">\n      <thead>\n        <tr>\n          <th class=\"col-data-log\">Data e hora (GMT)</th>\n          <th class=\"col-tipo\">Tipo</th>\n          <th class=\"col-interacao\">Interação</th>\n        </tr>\n      </thead>\n      <tbody>{{INTERACOES_HTML}}</tbody>\n    </table>\n  </div>\n\n  <!-- Termos e CCB vêm só em PDF (anexosPdf → config.pdfsAnexos ou pdfsAnexosBase64), não neste HTML. -->\n\n  <!-- ═══ Prova de vida ═══ Nome nesta secção: {{PROVA_VIDA_NOME}} (pode coincidir com CLIENTE_NOME ou vir do payload provaDeVida.nome). -->\n  <div class=\"dossie-section\">\n    <div class=\"section-title\" style=\"margin-top:0;\">Prova de vida</div>\n    <div style=\"margin-bottom:10px;\">\n      <span class=\"field-label\">Nome do cliente</span>\n      <span class=\"field-value\">{{PROVA_VIDA_NOME}}</span>\n    </div>\n    <div class=\"img-container\">\n      <img src=\"{{IMG_SELFIE}}\" alt=\"Prova de vida\" />\n    </div>\n  </div>\n\n  <!-- ═══ Documentos ═══ -->\n  <div class=\"dossie-section\">\n    <div class=\"section-title\" style=\"margin-top:0;\">Documentos</div>\n    <p style=\"font-weight:700;margin-bottom:10px;\">{{DOCUMENTO_TIPO}}</p>\n    <div class=\"img-doc-container\"><img src=\"{{IMG_DOCUMENTO_FRENTE}}\" alt=\"Documento frente\" /></div>\n    <div class=\"img-doc-container\"><img src=\"{{IMG_DOCUMENTO_VERSO}}\" alt=\"Documento verso\" /></div>\n  </div>\n\n</body>\n</html>\n",
    "requiredFields": []
  },
