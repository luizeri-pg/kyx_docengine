# Copiar para .env na mesma pasta e preencher antes de: docker stack deploy -c compose.stack.yaml docengine
# Build das imagens (exemplo):
#   docker build -t ${REGISTRY}/docengine-api:${TAG} backend/KYX.DocEngine.API
#   docker build --build-arg VITE_API_URL=https://${API_HOST} -t ${REGISTRY}/docengine-web:${TAG} frontend

REGISTRY=your-registry.azurecr.io
TAG=latest
STACK_NAME=dev

# DNS públicos (Traefik / TLS)
API_HOST=api.docengine.example.com
WEB_HOST=app.docengine.example.com

# Postgres (stack interno)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=docengine

# JWT (mín. 32 caracteres em produção)
JWT_SECRET_KEY=change-me-in-production-minimum-32-characters!!
