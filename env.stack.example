# Copiar para .env na raiz do repo:  cp env.stack.example .env
#
# Automático (depois de docker login no registry e docker swarm init):
#   chmod +x scripts/stack-*.sh
#   ./scripts/stack-all.sh
#
# Ou passo a passo: ./scripts/stack-setup-network.sh
#                    ./scripts/stack-build-push.sh
#                    ./scripts/stack-deploy.sh

# Azure: após o pipeline fazer push no ACR, usa o login server do registo, ex.:
# REGISTRY=meuacr.azurecr.io
# TAG=latest   # ou o número do build $(Build.BuildId) se fixares no deploy
REGISTRY=your-registry.azurecr.io
TAG=latest
STACK_NAME=dev
# Nome do stack no Swarm (docker stack deploy)
STACK_DEPLOY_NAME=docengine
# 1 = só build, sem push (útil com REGISTRY=local no Mac)
# SKIP_PUSH=0

# DNS públicos (Traefik / TLS)
API_HOST=api.docengine.example.com
WEB_HOST=app.docengine.example.com

# Postgres (stack interno)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=docengine

# JWT (mín. 32 caracteres em produção)
JWT_SECRET_KEY=change-me-in-production-minimum-32-characters!!
